{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TakashiSasaki/agent-policy/schemas/agent-policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "toolchain",
    "profiles",
    "project_policy",
    "outputs",
    "skills"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "revision"
      ],
      "properties": {
        "repository": {
          "const": "TakashiSasaki/agent-policy"
        },
        "revision": {
          "type": "string",
          "pattern": "^([0-9a-f]{40}|LOCAL-DEVELOPMENT)$"
        }
      }
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "project_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files"
      ],
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agents"
      ],
      "properties": {
        "agents": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "path"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "path": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "skills": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        }
      }
    }
  }
}
