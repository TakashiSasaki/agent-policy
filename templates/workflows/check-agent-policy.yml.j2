name: Check agent policy
on:
  pull_request:
    paths:
      - .agent-policy.yml
      - .agent-policy.lock
      - policy/**
      - AGENTS.md
      - .agents/skills/**
permissions:
  contents: read
jobs:
  check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2
      - uses: TakashiSasaki/agent-policy@{{ revision }}
        with:
          command: check
          config: .agent-policy.yml
